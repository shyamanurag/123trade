# Database Configuration
DATABASE_HOST=your_database_host
DATABASE_PORT=5432
DATABASE_NAME=your_database_name
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_database_password
DATABASE_URL=postgresql://username:password@localhost:5432/trading_db

# Redis Configuration
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_USERNAME=default
REDIS_SSL=false
REDIS_URL=redis://username:password@host:port

# TrueData API Configuration
TRUEDATA_API_KEY=your_truedata_api_key_here
TRUEDATA_API_SECRET=your_truedata_api_secret_here
TRUEDATA_CLIENT_ID=your_truedata_client_id_here
TRUEDATA_USERNAME=your_truedata_username_here
TRUEDATA_PASSWORD=your_truedata_password_here

# Security Configuration
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# API Keys
API_KEY=your_api_key_here

# Application Configuration
ENVIRONMENT=production
NODE_ENV=production
APP_PORT=8000
PORT=8000
FRONTEND_URL=https://your-frontend-domain.com
APP_URL=https://your-app-domain.com

# Optional: Development Settings
DEBUG=false
DISABLE_REDIS=false
